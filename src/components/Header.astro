---
import { SITE_TITLE, NAV_LINKS } from '../consts';
import { withBase } from '../lib/path';

// 現在のパスとリンクが一致するか（アクティブ表示用）
const current = Astro.url.pathname.replace(/\/$/, '');
function isActive(href: string): boolean {
  const target = withBase(href).replace(/\/$/, '');
  return href === '' ? current === target : current.startsWith(target);
}
---

<header class="border-b border-gray-200 dark:border-gray-800">
  <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
    <a href={withBase()} class="text-lg font-bold tracking-tight">
      {SITE_TITLE}
    </a>
    <nav class="flex gap-5 text-sm">
      {
        NAV_LINKS.map((link) => (
          <a
            href={withBase(link.href)}
            class:list={[
              'transition-colors hover:text-blue-600 dark:hover:text-blue-400',
              isActive(link.href)
                ? 'font-semibold text-blue-600 dark:text-blue-400'
                : 'text-gray-600 dark:text-gray-300',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>
