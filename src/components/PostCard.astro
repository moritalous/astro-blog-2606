---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';
import { postPath, tagPath } from '../lib/path';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
---

<article class="border-b border-gray-100 py-6 dark:border-gray-800">
  <h2 class="text-xl font-semibold">
    <a
      href={postPath(post.id)}
      class="hover:text-blue-600 dark:hover:text-blue-400"
    >
      {title}
    </a>
  </h2>
  <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">
    <FormattedDate date={pubDate} />
  </p>
  <p class="mt-2 text-gray-700 dark:text-gray-300">{description}</p>
  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li>
            <a
              href={tagPath(tag)}
              class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-gray-600 hover:bg-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
            >
              #{tag}
            </a>
          </li>
        ))}
      </ul>
    )
  }
</article>
